let guitar_8 = electricGuitar(
  arrange(
    ...[
      { offset: 24, fadeIn: 24, hold: 34, fadeOut: 20, scaleNote: "4", scale: arrangeKeys[0] },
      { offset: 3,  fadeIn: 27, hold: 28, fadeOut: 26, scaleNote: "2", scale: arrangeKeys[0] },
      { offset: 3,  fadeIn: 27, hold: 38, fadeOut: 16, scaleNote: "1", scale: arrangeKeys[0] },
      // 2 '~' eightnotes added by genFadeInFadeOut()
    ].genFadeInFadeOut(),
    [41,
        "~!8"
        .gain(0)
    ],
    ...[
      { offset: 3, fadeIn: 29, hold: 34, fadeOut: 18, scaleNote: "4", scale: arrangeKeys[2] },
      { offset: 3, fadeIn: 25, hold: 34, fadeOut: 22, scaleNote: "2", scale: arrangeKeys[2] },
      { offset: 3, fadeIn: 29, hold: 26, fadeOut: 46, scaleNote: "1", scale: arrangeKeys[2] },
