              2 2 3 2 0 ~ -1 -1 \
              2 0 ~ 2 0 ~ -1 -1 \
              2 2 3 2 0 ~ -1 -1 \
              2 ~ ~ 2 0 ~ -1 -1 \
              "
        .scale(arrangeKeys[4])
        .gain(g)
        .apply(rot(24,32))
        .slow(4)
    ],
    [1000, "~"]
  )
).color(colors[7]).seed(7)

