    [3+20*4+1,
        "~"
    ],
    [3+4," \
              ~ ~ 3 2 0 ~ ~ ~ \
              2 0 ~ 2 0 ~ ~ ~ \
              ~ ~ 3 2 0 ~ ~ ~ \
              2 ~ ~ 2 0 ~ ~ ~ \
              "
        .scale(arrangeKeys[2])
        .gain(g)
        .slow(4)
    ],
    [4*12+1," \
              2 2 3 2 0 ~ -1 -1 \
              2 0 ~ 2 0 ~ -1 -1 \
              2 2 3 2 0 ~ -1 -1 \
              2 ~ ~ 2 0 ~ -1 -1 \
              "
        .scale(arrangeKeys[2])
        .gain(g)
        .apply(rot(24,32))
        .slow(4)
