// Electric Counterpoint Fast I - Steve Reich
// Made with love by <3<

let g = .04

// This produces
// [tonal] error: invalid scale step "~", expected number or integer with optional # b suffixes
// probably due to using `~` in forEach instead of "~" but it works anyway
// "~" doesnt work cause `m is not a function`
Array.prototype.genFirstMovement = function () {
  const sequence = [];

  this.forEach(m => {    
    const total = m.fadeIn + m.hold + m.fadeOut;
    console.log(total)
    
    // offset
    for (let i = 0; i < m.offset; i++) {
      sequence.push({
        note: '~',
        gain: 0,
        scale: '~'
      });
    }

    // notes
    for (let i = 0; i < m.fadeIn; i++) {
      sequence.push({
        note: m.scaleNote,
        gain: (i / m.fadeIn) * g,
        scale: m.scale
      });
    }
    for (let i = 0; i < m.hold; i++) {
      sequence.push({
        note: m.scaleNote,
        gain: g,
        scale: m.scale
      });
    }
    for (let i = 0; i < m.fadeOut; i++) {
      sequence.push({
        note: m.scaleNote,
        gain: ((m.fadeOut - i) / m.fadeOut) * g,
        scale: m.scale
      });
    }
  });
  
  // split into bars of 8
  const bars = [];

  for (let i = 0; i < sequence.length; i += 8) {
    const chunk = sequence.slice(i, i + 8);

    while (chunk.length < 8) {
      chunk.push({ note: "~", gain: 0, scale: "~" });
    }

    const notes = chunk.map(e => e.note);
    const gains = chunk.map(e => e.gain);
    const scales = chunk.map(e => e.scale);

    bars.push([
      1,
      seq(notes).scale(seq(scales)).gain(seq(gains))
    ]);
  }

  return bars;
};

const guitar = (pattern) =>
     pattern
    .note()
    .cpm(192/4)
    .adsr("0:5:.7:1.5")
    .lpq(0)
    .early(perlin.range(-0.01,0.01))
    .postgain(perlin.range(0.95,1.05)) // Add some dynamics so it feels more live

// A “electric guitar” subclass
const electricGuitar = (pattern) =>
     guitar(pattern)
    .sound("gm_acoustic_guitar_nylon")
    .lpf(1000)
    .room(.2)

// A “bass guitar” subclass
const bassGuitar = (pattern) =>
     guitar(pattern)
    .lpf(1050)
    .sound("gm_acoustic_bass")
    .postgain(0.6)

guitar_1: electricGuitar(
  arrange(
    // Pages 1-26
    [26,
        "~!32"
        .gain(0)
    ],

    // Ugly escape
    [100, "~"]
  )
)

