      { offset: 0, fadeIn: 24, hold: 42, fadeOut: 16, scaleNote: 11, scale: "E4:Minor" },
      { offset: 3, fadeIn: 27, hold: 44, fadeOut: 18, scaleNote: 9,  scale: "E4:Minor" },
      { offset: 3, fadeIn: 31, hold: 36, fadeOut: 20, scaleNote: 8,  scale: "E4:Minor" },
      { offset: 9, fadeIn: 23, hold: 36, fadeOut: 16, scaleNote: 6,  scale: "C5:Minor" },
      { offset: 3, fadeIn: 25, hold: 38, fadeOut: 12, scaleNote: 6,  scale: "C5:Minor" },
      { offset: 3, fadeIn: 27, hold: 32, fadeOut: 16, scaleNote: 4,  scale: "C5:Minor" },
      { offset: 3, fadeIn: 21, hold: 42, fadeOut: 18, scaleNote: 6,  scale: "C5:Minor" },
      { offset: 9, fadeIn: 27, hold: 28, fadeOut: 20, scaleNote: 11, scale: "E4:Minor" },
      { offset: 3, fadeIn: 21, hold: 42, fadeOut: 18, scaleNote: 9,  scale: "E4:Minor" },
      { offset: 3, fadeIn: 25, hold: 42, fadeOut: 46, scaleNote: 11, scale: "E4:Minor" },
    ].genFirstMovement(),
    [100, "~"]
  )
)

