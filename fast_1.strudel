    [2+12*3+2," \
              -3 -3 -2 -3 -5 ~ -6 -6 \
              -3 -5 ~  -3 -5 ~ -6 -6 \
              -3 -3 -2 -3 -5 ~ -6 -6 \
              -3 ~  ~  -3 -5 ~ -6 -6 \
              "
        .scale(arrangeKeys[3])
        .gain(g)
        .slow(4)
